# ==================================================
# TaskForge — Environment Configuration
# ==================================================
# Copy this file to .env and update the values below.
# Do NOT commit .env to version control.
# ==================================================

# -- Application Settings --
APP_NAME=TaskForge
APP_ENV=development
APP_URL=http://localhost/TaskForge/public

# -- Database (XAMPP Default) --
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=taskforge
DB_USERNAME=root
DB_PASSWORD=

# -- Google Gemini AI --
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=models/gemini-2.5-flash
